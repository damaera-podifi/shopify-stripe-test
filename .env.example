SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# products, cart
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
SHOPIFY_ADMIN_ACCESS_TOKEN=your_admin_access_token
# Admin-based member pricing (automatic when logged in — no OAuth)
# Copy segment GID from Shopify Admin → Customers → Segments → your segment
SHOPIFY_SEGMENT_IDS=gid://shopify/Segment/YOUR_SEGMENT_ID
SHOPIFY_MEMBER_DISCOUNT_PERCENT=10
# SHOPIFY_MEMBER_DISCOUNT_TITLE=VIP discount

# Optional: exact Shopify segment prices via Customer Account OAuth
# SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=shp_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# for creating order
SHOPIFY_APP_CLIENT_ID=your_app_client_id
SHOPIFY_APP_CLIENT_SECRET=shpss_your_app_client_secret

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
