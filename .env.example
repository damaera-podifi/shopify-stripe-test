# Shopify store (custom app or dev store)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API — products, cart, customer create/update on login
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Admin API — order fulfillment after Stripe payment
# Use ONE of the two options below:
#
# static Admin API access token (custom app)
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# OAuth client credentials (Dev Dashboard app)
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=

# Stripe (test keys for local dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: dev server port (default 3000). Or: pnpm dev -- -p 6000
# PORT=3000
